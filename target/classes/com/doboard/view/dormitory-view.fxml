<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../../styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="doboard.core.controllers.DormitoryController">
    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #406AAF;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <Label text="DoBoard" textFill="#ffd94c">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="30.0" />
                </VBox.margin>
            </Label>
            
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#goToDashboard" styleClass="navBtn" text="Dashboard" />
            <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="navBtn" text="My Dorm" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#goToChores" styleClass="navBtn" text="Chores" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#goToBills" styleClass="navBtn" text="Bills" />
            
            <VBox VBox.vgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#logout" styleClass="navBtn" text="Logout" />
        </VBox>
    </left>
    
    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20.0" style="-fx-background-color: #F4F6F9;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            
            <Label text="My Dormitory" textFill="#406aaf">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>

            <!-- NO DORM VIEW -->
            <VBox fx:id="noDormBox" spacing="20.0">
                <HBox spacing="20.0">
                    <VBox prefHeight="200.0" prefWidth="350.0" spacing="10.0" styleClass="dashboardCard">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                        <Label text="Create a Dorm" textFill="#406aaf">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Start a new dorm and become the admin." textFill="#666666" />
                        <TextField fx:id="createDormNameField" promptText="Enter Dorm Name" styleClass="input-field" />
                        <Button mnemonicParsing="false" onAction="#handleCreateDorm" styleClass="entryBtn" text="Create Dorm" />
                    </VBox>
                    
                    <VBox prefHeight="200.0" prefWidth="350.0" spacing="10.0" styleClass="dashboardCard">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                        <Label text="Join a Dorm" textFill="#406aaf">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Have an invite code? Join an existing dorm." textFill="#666666" />
                        <TextField fx:id="joinCodeField" promptText="Enter Invite Code" styleClass="input-field" />
                        <Button mnemonicParsing="false" onAction="#handleJoinDorm" styleClass="entryBtn" text="Join Dorm" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- HAS DORM VIEW -->
            <VBox fx:id="hasDormBox" spacing="20.0" visible="false" managed="false">
                <VBox prefWidth="600.0" spacing="10.0" styleClass="dashboardCard">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <Label fx:id="dormNameLabel" text="Dorm: [Name]" textFill="#406aaf">
                        <font>
                            <Font name="System Bold" size="22.0" />
                        </font>
                    </Label>
                    <Label fx:id="joinCodeDisplayLabel" text="Invite Code: [Code]" textFill="#666666">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                </VBox>
            </VBox>
            
        </VBox>
    </center>
</BorderPane>
